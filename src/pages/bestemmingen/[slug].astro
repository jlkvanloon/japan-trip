---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("destinations");
  const sorted = entries.map(e => e.data).sort(
    (a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime()
  );
  const tripStart = new Date(sorted[0].startDate).getTime();

  return entries.map((entry) => {
    const destStart = new Date(entry.data.startDate).getTime();
    const dayOffset = Math.round((destStart - tripStart) / 86400000);
    return {
      params: { slug: entry.data.slug },
      props: { dest: entry.data, dayOffset },
    };
  });
}

const { dest, dayOffset } = Astro.props;

function fmtDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("nl-NL", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

function nights(start: string, end: string) {
  const diff = (new Date(end).getTime() - new Date(start).getTime()) / 86400000;
  return diff === 1 ? "1 nacht" : `${diff} nachten`;
}
---

<Layout title={`${dest.name} — Japan 2026`}>
  <div class="dest-page">
    <div class="container">
      <a href="/" class="back-link">&larr; Terug naar overzicht</a>

      <div class="dest-hero">
        <div class="dest-accent" style={`background: var(--accent)`}></div>
        <div class="dest-hero-content">
          <h1>{dest.name}</h1>
          <p class="dest-period">
            {fmtDate(dest.startDate)} &ndash; {fmtDate(dest.endDate)}
            &nbsp;&middot;&nbsp;
            {nights(dest.startDate, dest.endDate)}
          </p>
        </div>
      </div>

      <div class="dest-grid">
        <!-- Travel entries -->
        {dest.travel.map((reis) => (
          <section class="info-card">
            <h2 class="info-card-title">{reis.titel}</h2>
            <dl>
              <dt>Vertrek vanuit</dt>
              <dd>{reis.from}</dd>
              <dt>Vervoer</dt>
              <dd>{reis.method}</dd>
              {reis.tijden && <><dt>Tijden</dt><dd>{reis.tijden}</dd></>}
              {reis.vluchtnummer && <><dt>Vluchtnummer</dt><dd>{reis.vluchtnummer}</dd></>}
              {reis.treinnummer && <><dt>Treinnummer</dt><dd>{reis.treinnummer}</dd></>}
              {reis.duur && <><dt>Duur</dt><dd>{reis.duur}</dd></>}
              {reis.klasse && <><dt>Klasse</dt><dd>{reis.klasse}</dd></>}
              {reis.bagage && <><dt>Bagage</dt><dd>{reis.bagage}</dd></>}
            </dl>
          </section>
        ))}

        <!-- Hotel -->
        <section class="info-card">
          <h2 class="info-card-title">
            Verblijf
          </h2>
          <dl>
            <dt>Hotel</dt>
            <dd>
              {dest.hotel.url
                ? <a href={dest.hotel.url} target="_blank" class="hotel-link">{dest.hotel.name}</a>
                : dest.hotel.name}
            </dd>
            {dest.hotel.checkIn && <><dt>Incheck</dt><dd>{dest.hotel.checkIn}</dd></>}
            {dest.hotel.checkOut && <><dt>Uitcheck</dt><dd>{dest.hotel.checkOut}</dd></>}
            {dest.hotel.breakfast && <><dt>Ontbijt</dt><dd>{dest.hotel.breakfast}</dd></>}
            {dest.hotel.payment && <><dt>Betaling</dt><dd>{dest.hotel.payment}</dd></>}
            {dest.hotel.opmerkingen && <><dt>Opmerkingen</dt><dd>{dest.hotel.opmerkingen}</dd></>}
          </dl>
        </section>
      </div>

      <!-- Dag planning -->
      {dest.dagplanning && dest.dagplanning.length > 0 && (
        <section class="activities-section">
          <h2>Dag planning</h2>
          <div class="activity-list">
            {dest.dagplanning.map((dag, i) => (
              <article class="activity-card" style={`--dest-color: var(--accent)`}>
                <div class="activity-when">
                  <span class="when-day">Dag {dayOffset + i + 1}</span>
                  <span class="when-period">{dag.titel}</span>
                </div>
                <div class="activity-body">
                  {dag.subsections && dag.subsections.length > 0 ? (
                    <div class="subsection-list">
                      {dag.subsections.map((sub) => (
                        <div class="subsection">
                          <h4 class="subsection-title">{sub.titel}</h4>
                          <p class="subsection-desc">{sub.beschrijving}</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p class="activity-desc">{dag.content}</p>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {dest.restaurants && dest.restaurants.length > 0 && (
        <section class="restaurants-section">
          <h2>Restaurants</h2>
          <div class="restaurant-list">
            {dest.restaurants.map((r: any) => (
              <div class="restaurant-card" style={`--dest-color: var(--accent)`}>
                <div class="restaurant-header">
                  <strong class="restaurant-name">{r.name}</strong>
                  <span class="restaurant-type">{r.type}</span>
                </div>
                {r.notes && <p class="restaurant-notes">{r.notes}</p>}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  .dest-page {
    padding: 40px 0 80px;
  }

  .hotel-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 32px;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--text);
  }

  .dest-hero {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 48px;
  }

  .dest-accent {
    width: 6px;
    height: 72px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .dest-hero-content h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: 8px;
  }

  .dest-period {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .dest-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
  }

  .info-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
  }

  .info-card-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .info-icon {
    font-size: 1rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    align-items: baseline;
  }

  dt {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  dd {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .activities-section h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .activity-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 3px solid var(--dest-color, var(--accent));
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.15s;
  }

  .activity-card:hover {
    box-shadow: var(--shadow);
  }

  .activity-when {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 12px 24px;
    background: color-mix(in srgb, var(--dest-color, var(--accent)) 12%, transparent);
    border-bottom: 1px solid var(--border);
  }

  .when-day {
    font-family: "Shippori Mincho", serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dest-color, var(--accent));
  }

  .when-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .activity-body {
    padding: 20px 24px;
  }

  .activity-title {
    font-size: 1.15rem;
    margin-bottom: 10px;
    color: var(--text);
  }

  .activity-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .subsection-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .subsection {
    padding-left: 12px;
    border-left: 2px solid color-mix(in srgb, var(--dest-color, var(--accent)) 40%, transparent);
  }

  .subsection-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 4px;
  }

  .subsection-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .restaurants-section {
    margin-top: 48px;
  }

  .restaurants-section h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .restaurant-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .restaurant-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 3px solid var(--dest-color, var(--accent));
    border-radius: var(--radius-lg);
    padding: 20px 24px;
  }

  .restaurant-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .restaurant-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .restaurant-type {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dest-color, var(--accent));
    white-space: nowrap;
  }

  .restaurant-notes {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .dest-grid {
      grid-template-columns: 1fr;
    }

    .activity-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
