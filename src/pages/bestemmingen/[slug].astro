---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("destinations");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { dest: entry.data },
  }));
}

const { dest } = Astro.props;

function fmtDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("nl-NL", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

function nights(start: string, end: string) {
  const diff = (new Date(end).getTime() - new Date(start).getTime()) / 86400000;
  return diff === 1 ? "1 nacht" : `${diff} nachten`;
}
---

<Layout title={`${dest.name} — Japan 2026`}>
  <div class="dest-page">
    <div class="container">
      <a href="/" class="back-link">&larr; Terug naar overzicht</a>

      <div class="dest-hero">
        <div class="dest-accent" style={`background: ${dest.color}`}></div>
        <div class="dest-hero-content">
          <h1>{dest.name}</h1>
          <p class="dest-period">
            {fmtDate(dest.startDate)} &ndash; {fmtDate(dest.endDate)}
            &nbsp;&middot;&nbsp;
            {nights(dest.startDate, dest.endDate)}
          </p>
        </div>
      </div>

      <div class="dest-grid">
        <!-- Travel -->
        <section class="info-card">
          <h2 class="info-card-title">
            Reizen
          </h2>
          <dl>
            <dt>Vertrek vanuit</dt>
            <dd>{dest.travel.from}</dd>
            <dt>Vervoer</dt>
            <dd>{dest.travel.method}</dd>
            <dt>Details</dt>
            <dd>{dest.travel.details}</dd>
          </dl>
        </section>

        <!-- Hotel -->
        <section class="info-card">
          <h2 class="info-card-title">
            Verblijf
          </h2>
          <dl>
            <dt>Hotel</dt>
            <dd>{dest.hotel.name}</dd>
            <dt>Adres</dt>
            <dd>{dest.hotel.address}</dd>
            {
              dest.hotel.notes && (
                <>
                  <dt>Notities</dt>
                  <dd>{dest.hotel.notes}</dd>
                </>
              )
            }
          </dl>
        </section>
      </div>

      <!-- Activities -->
      <section class="activities-section">
        <h2>
          Activiteiten
        </h2>

        <div class="activity-list">
          {
            [...dest.activities.detailed].sort((a: any, b: any) => {
              const dayNum = (when: string) => parseInt(when.match(/\d+/)?.[0] ?? "0");
              return dayNum(a.when) - dayNum(b.when);
            }).map((act: any) => (
              <article class="activity-card" style={`--dest-color: ${dest.color}`}>
                <div class="activity-when">
                  {act.when.split("—").map((part: string, i: number) => (
                    <span class={i === 0 ? "when-day" : "when-period"}>{part.trim()}</span>
                  ))}
                </div>
                <div class="activity-body">
                  <h3 class="activity-title">{act.name}</h3>
                  <p class="activity-desc">{act.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      {dest.restaurants && dest.restaurants.length > 0 && (
        <section class="restaurants-section">
          <h2>Restaurants</h2>
          <div class="restaurant-list">
            {dest.restaurants.map((r: any) => (
              <div class="restaurant-card" style={`--dest-color: ${dest.color}`}>
                <div class="restaurant-header">
                  <strong class="restaurant-name">{r.name}</strong>
                  <span class="restaurant-type">{r.type}</span>
                </div>
                {r.notes && <p class="restaurant-notes">{r.notes}</p>}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  .dest-page {
    padding: 40px 0 80px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 32px;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--text);
  }

  .dest-hero {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 48px;
  }

  .dest-accent {
    width: 6px;
    height: 72px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .dest-hero-content h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: 8px;
  }

  .dest-period {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .dest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  .info-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
  }

  .info-card-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .info-icon {
    font-size: 1rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    align-items: baseline;
  }

  dt {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  dd {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .activities-section h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .activity-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 3px solid var(--dest-color, var(--accent));
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.15s;
  }

  .activity-card:hover {
    box-shadow: var(--shadow);
  }

  .activity-when {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 12px 24px;
    background: color-mix(in srgb, var(--dest-color, var(--accent)) 12%, transparent);
    border-bottom: 1px solid var(--border);
  }

  .when-day {
    font-family: "Shippori Mincho", serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dest-color, var(--accent));
  }

  .when-period {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .activity-body {
    padding: 20px 24px;
  }

  .activity-title {
    font-size: 1.15rem;
    margin-bottom: 10px;
    color: var(--text);
  }

  .activity-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .restaurants-section {
    margin-top: 48px;
  }

  .restaurants-section h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .restaurant-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .restaurant-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 3px solid var(--dest-color, var(--accent));
    border-radius: var(--radius-lg);
    padding: 20px 24px;
  }

  .restaurant-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .restaurant-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .restaurant-type {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dest-color, var(--accent));
    white-space: nowrap;
  }

  .restaurant-notes {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .dest-grid {
      grid-template-columns: 1fr;
    }

    .activity-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
