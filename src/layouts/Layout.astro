---
import { theme } from '../config/theme';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Onze reis door Japan — november / december 2026" } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style set:html={`
      :root {
        --bg:          ${theme.bg};
        --surface:     ${theme.surface};
        --text:        ${theme.text};
        --text-muted:  ${theme.textMuted};
        --border:      ${theme.border};
        --accent:      ${theme.accent};
        --accent-dark: ${theme.accentDark};
        --shadow:      0 2px 12px rgba(80, 30, 20, 0.12);
        --shadow-lg:   0 8px 32px rgba(80, 30, 20, 0.18);
        --radius:      8px;
        --radius-lg:   16px;
      }
    `} />
    <!-- Hide gate immediately for already-authenticated visitors -->
    <script is:inline>
      (function () {
        var FIFTEEN_MIN = 15 * 60 * 1000;
        var unlockedAt = parseInt(localStorage.getItem('japan-unlocked-at') || '0', 10);
        if (localStorage.getItem('japan-unlocked') === '1' && Date.now() - unlockedAt < FIFTEEN_MIN) {
          document.documentElement.classList.add('unlocked');
        } else {
          localStorage.removeItem('japan-unlocked');
          localStorage.removeItem('japan-unlocked-at');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Entrance gate -->
    <div id="gate" class="gate" aria-label="Toegangsscherm" role="dialog">
      <div class="gate-inner">
        <div class="gate-logo">
          <span class="gate-kanji">日本</span>
          <span class="gate-title">Japan 2026</span>
        </div>
        <p class="gate-sub">私たちの旅</p>
        <form id="gate-form" class="gate-form">
          <input
            id="gate-input"
            type="password"
            class="gate-input"
            placeholder="wachtwoord"
            autocomplete="off"
            autofocus
          />
          <p id="gate-error" class="gate-error" hidden>Onjuist wachtwoord — probeer opnieuw</p>
        </form>
      </div>
    </div>

    <header>
      <div class="container">
        <a href="/" class="logo">
          <span class="logo-jp">日本</span>
          <span class="logo-text">Japan 2026</span>
        </a>
        <span class="countdown" id="countdown"></span>
      </div>
    </header>
    <script is:inline>
      (function() {
        const departure = new Date(2026, 10, 19); // Nov 19 2026
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const days = Math.round((departure - today) / 86400000);
        const el = document.getElementById('countdown');
        if (el && days > 0) el.textContent = 'Nog ' + days + ' dagen';
        else if (el && days === 0) el.textContent = 'Vandaag!';
      })();
    </script>

    <main>
      <slot />
    </main>

    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>

    <script is:inline>
      (function () {
        var gate  = document.getElementById('gate');
        var form  = document.getElementById('gate-form');
        var input = document.getElementById('gate-input');
        var error = document.getElementById('gate-error');

        function unlock() {
          localStorage.setItem('japan-unlocked', '1');
          localStorage.setItem('japan-unlocked-at', Date.now().toString());
          gate.classList.add('gate--out');
          gate.addEventListener('transitionend', function () { gate.remove(); }, { once: true });
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          if (input.value === 'korte') {
            unlock();
          } else {
            error.hidden = false;
            input.value = '';
            input.classList.add('gate-input--shake');
            input.addEventListener('animationend', function () {
              input.classList.remove('gate-input--shake');
            }, { once: true });
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Shippori+Mincho:wght@400;600&display=swap");

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: "Noto Sans JP", system-ui, sans-serif;
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: "Shippori Mincho", serif;
    font-weight: 600;
    line-height: 1.3;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    border-bottom: 1px solid var(--accent-dark);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background: var(--accent-dark);
    backdrop-filter: blur(8px);
    z-index: 100;
    color: #ffffff;
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-jp {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #ffffff;
    opacity: 0.85;
  }

  .logo-text {
    font-family: "Shippori Mincho", serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .countdown {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
    font-family: "Noto Sans JP", sans-serif;
    letter-spacing: 0.03em;
  }

  nav a {
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  nav a:hover {
    color: var(--text);
  }

  /* Gate */

  html.unlocked #gate {
    display: none;
  }

  .gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--accent-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
  }

  .gate--out {
    opacity: 0;
    pointer-events: none;
  }

  .gate-inner {
    text-align: center;
    color: #fff;
    padding: 24px;
  }

  .gate-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 10px;
  }

  .gate-kanji {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 2.8rem;
    font-weight: 500;
    opacity: 0.85;
    line-height: 1;
  }

  .gate-title {
    font-family: "Shippori Mincho", serif;
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .gate-sub {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 0.8rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.2em;
    margin-bottom: 52px;
  }

  .gate-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .gate-input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius);
    color: #fff;
    font-family: "Noto Sans JP", sans-serif;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    outline: none;
    padding: 14px 24px;
    text-align: center;
    transition: border-color 0.2s, background 0.2s;
    width: 240px;
  }

  .gate-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.06em;
  }

  .gate-input:focus {
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .gate-error {
    color: rgba(255, 210, 200, 0.9);
    font-family: "Noto Sans JP", sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    margin-top: 14px;
    letter-spacing: 0.02em;
  }

  @keyframes gate-shake {
    0%, 100% { transform: translateX(0); }
    20%       { transform: translateX(-8px); }
    40%       { transform: translateX(8px); }
    60%       { transform: translateX(-5px); }
    80%       { transform: translateX(5px); }
  }

  .gate-input--shake {
    animation: gate-shake 0.4s ease;
  }
</style>
