---
interface Destination {
  slug: string;
  name: string;
  startDate: string;
  endDate: string;
  color: string;
  travel: { from: string; method: string; details: string };
  hotel: { name: string; address: string; notes?: string };
  activities: { brief: string[]; detailed: any[] };
}

interface Props {
  destinations: Destination[];
}

const { destinations } = Astro.props;

const sorted = [...destinations].sort(
  (a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime()
);

// Use local-time date strings to avoid UTC off-by-one errors
function toDateStr(d: Date): string {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

// Parse YYYY-MM-DD strings as local dates (not UTC midnight)
function parseDate(s: string): Date {
  const [y, m, d] = s.split("-").map(Number);
  return new Date(y, m - 1, d);
}

const tripStartStr = sorted[0].startDate;
const tripEndStr = sorted[sorted.length - 1].endDate;

const MONTH_SHORT: Record<number, string> = {
  10: "nov", 11: "dec",
};

function getDestForDate(dateStr: string): Destination | null {
  return sorted.find((d) => dateStr >= d.startDate && dateStr < d.endDate) ?? null;
}

type CalDay = {
  date: Date;
  dateStr: string;
  monthLabel: string;
  dest: Destination | null;
  inTrip: boolean;
  isFirst: boolean;
};

// Build one unified grid from the Monday of the week containing tripStart
// to the Sunday of the week containing tripEnd
const gridStart = parseDate(tripStartStr);
gridStart.setDate(gridStart.getDate() - (gridStart.getDay() + 6) % 7);

const gridEnd = parseDate(tripEndStr);
const endDow = (gridEnd.getDay() + 6) % 7;
gridEnd.setDate(gridEnd.getDate() + (6 - endDow));

const allDays: (CalDay | null)[] = [];
const cursor = new Date(gridStart);
while (cursor <= gridEnd) {
  const dateStr = toDateStr(cursor);
  const dest = getDestForDate(dateStr);
  const inTrip = dateStr >= tripStartStr && dateStr <= tripEndStr;
  const nextDay = toDateStr(new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate() + 1));
  allDays.push({
    date: new Date(cursor),
    dateStr,
    monthLabel: MONTH_SHORT[cursor.getMonth()] ?? "",
    dest,
    inTrip,
    isFirst: !!(dest && dateStr === dest.startDate),
  });
  cursor.setDate(cursor.getDate() + 1);
}

// Group allDays into weeks of 7
const weeks: CalDay[][] = [];
for (let i = 0; i < allDays.length; i += 7) {
  weeks.push(allDays.slice(i, i + 7) as CalDay[]);
}

// For each week, compute which destination spans which columns (1-indexed)
type LabelSpan = { dest: Destination; colStart: number; colEnd: number };

function getSpans(week: CalDay[]): LabelSpan[] {
  const spans: LabelSpan[] = [];
  let i = 0;
  while (i < 7) {
    const day = week[i];
    if (day && day.inTrip && day.dest) {
      const slug = day.dest.slug;
      let j = i;
      while (j < 7 && week[j]?.dest?.slug === slug) j++;
      spans.push({ dest: day.dest, colStart: i + 1, colEnd: j });
      i = j;
    } else {
      i++;
    }
  }
  return spans;
}

const weekdays = ["Ma", "Di", "Wo", "Do", "Vr", "Za", "Zo"];

function nights(start: string, end: string) {
  const diff = (new Date(end).getTime() - new Date(start).getTime()) / 86400000;
  return diff === 1 ? "1 nacht" : `${diff} nachten`;
}

function fmtShort(dateStr: string) {
  return parseDate(dateStr).toLocaleDateString("nl-NL", { day: "numeric", month: "short" });
}
---

<section class="cal-section">
  <div class="container">

    <div class="cal-layout">
      <!-- Calendar: weekday header + one label+cells pair per week -->
      <div class="cal-wrap">
        <!-- Weekday header -->
        <div class="cal-grid cal-header">
          {weekdays.map((d) => <div class="cal-weekday">{d}</div>)}
        </div>

        {weeks.map((week) => {
          const spans = getSpans(week);
          return (
            <div class="week-block">
              {/* Destination label row */}
              <div class="cal-grid label-row">
                {spans.map(({ dest, colStart, colEnd }) => (
                  <button
                    class="dest-label"
                    style={`grid-column: ${colStart} / ${colEnd + 1}; --dest-color: ${dest.color}`}
                    data-slug={dest.slug}
                  >
                    {dest.name}
                  </button>
                ))}
              </div>
              {/* Day cells */}
              <div class="cal-grid day-row">
                {week.map((day) => {
                  if (!day || !day.inTrip) return <div class="cal-day cal-day--empty" />;
                  return (
                    <button
                      class:list={["cal-day", day.dest ? "cal-day--trip" : "cal-day--off"]}
                      style={day.dest ? `--dest-color: ${day.dest.color}` : ""}
                      data-slug={day.dest?.slug}
                      disabled={!day.dest}
                      aria-label={day.dest ? `${day.date.getDate()} ${day.monthLabel} — ${day.dest.name}` : `${day.date.getDate()} ${day.monthLabel}`}
                    >
                      <span class="day-num">{day.date.getDate()}</span>
                      <span class="day-month">{day.monthLabel}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </div>
</section>

<!-- Popup -->
<div id="popup-overlay" class="popup-overlay" hidden>
  <div class="popup" role="dialog" aria-modal="true">
    <button class="popup-close" id="popup-close" aria-label="Sluiten">&times;</button>
    <h2 id="popup-title" class="popup-title"></h2>
    <p id="popup-dates" class="popup-dates"></p>

    <div class="popup-grid">
      <div class="popup-block">
        <div class="popup-block-label"><span class="popup-icon">✈</span> Reizen</div>
        <p id="popup-travel-method" class="popup-sub"></p>
        <p id="popup-travel-details"></p>
      </div>
      <div class="popup-block">
        <div class="popup-block-label"><span class="popup-icon">🏨</span> Verblijf</div>
        <p id="popup-hotel-name" class="popup-sub"></p>
        <p id="popup-hotel-address"></p>
      </div>
      <div class="popup-block popup-block--full">
        <div class="popup-block-label"><span class="popup-icon">🗺</span> Activiteiten</div>
        <ul id="popup-activities"></ul>
      </div>
    </div>

    <a id="popup-more" href="#" class="popup-cta">Bekijk alle details &rarr;</a>
  </div>
</div>

<script is:inline id="dest-data" type="application/json" set:html={JSON.stringify(
  sorted.map((d) => ({
    slug: d.slug,
    name: d.name,
    startDate: d.startDate,
    endDate: d.endDate,
    travel: d.travel,
    hotel: d.hotel,
    activities: { brief: d.activities.brief },
  }))
)} />

<script>
  const data: Record<string, any> = {};
  const raw = document.getElementById("dest-data")?.textContent;
  if (raw) {
    (JSON.parse(raw) as any[]).forEach((d) => (data[d.slug] = d));
  }

  const overlay = document.getElementById("popup-overlay") as HTMLElement;

  function fmtDate(str: string) {
    return new Date(str).toLocaleDateString("nl-NL", {
      weekday: "short", day: "numeric", month: "long",
    });
  }

  function openPopup(slug: string) {
    const d = data[slug];
    if (!d) return;
    (document.getElementById("popup-title") as HTMLElement).textContent = d.name;
    (document.getElementById("popup-dates") as HTMLElement).textContent =
      `${fmtDate(d.startDate)} – ${fmtDate(d.endDate)}`;
    (document.getElementById("popup-travel-method") as HTMLElement).textContent =
      `${d.travel.method} vanaf ${d.travel.from}`;
    (document.getElementById("popup-travel-details") as HTMLElement).textContent = d.travel.details;
    (document.getElementById("popup-hotel-name") as HTMLElement).textContent = d.hotel.name;
    (document.getElementById("popup-hotel-address") as HTMLElement).textContent = d.hotel.address;
    (document.getElementById("popup-activities") as HTMLElement).innerHTML =
      d.activities.brief.map((a: string) => `<li>${a}</li>`).join("");
    (document.getElementById("popup-more") as HTMLAnchorElement).href = `/bestemmingen/${slug}`;
    overlay.hidden = false;
    document.body.style.overflow = "hidden";
  }

  function closePopup() {
    overlay.hidden = true;
    document.body.style.overflow = "";
  }

  document.querySelectorAll("[data-slug]").forEach((el) => {
    el.addEventListener("click", () => openPopup((el as HTMLElement).dataset.slug!));
  });

  document.getElementById("popup-close")!.addEventListener("click", closePopup);
  overlay.addEventListener("click", (e) => { if (e.target === overlay) closePopup(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closePopup(); });
</script>

<style>
  .cal-section {
    padding: 60px 0 80px;
  }

  .trip-header {
    margin-bottom: 48px;
  }

  .trip-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 8px;
  }

  .trip-dates {
    color: var(--text-muted);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }

  .cal-layout {
    display: block;
  }

  .cal-wrap {}

  .week-block {
    margin-bottom: 4px;
  }

  .label-row {
    margin-bottom: 2px;
  }

  .dest-label {
    border: none;
    background: color-mix(in srgb, var(--dest-color) 22%, transparent);
    color: color-mix(in srgb, var(--dest-color) 85%, black);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    padding: 4px 6px;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: filter 0.15s;
  }

  .dest-label:hover {
    filter: brightness(0.92);
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(72px, 1fr));
    gap: 4px;
  }

  @media (max-width: 560px) {
    .cal-grid {
      grid-template-columns: repeat(7, 1fr);
      gap: 3px;
    }

    .cal-day {
      min-height: 80px;
    }

    .day-num {
      font-size: 1rem;
    }

    .day-month {
      font-size: 0.55rem;
    }
  }

  .cal-weekday {
    text-align: center;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    padding-bottom: 6px;
    font-weight: 500;
  }

  .cal-day {
    border: none;
    border-radius: 6px;
    cursor: default;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 4px;
    position: relative;
    transition: filter 0.15s, transform 0.12s;
    overflow: hidden;
    min-height: 72px;
  }

  .cal-day--empty {
    background: transparent;
  }

  .cal-day--off {
    background: transparent;
    pointer-events: none;
  }

  .cal-day--off .day-num {
    color: var(--text-muted);
    opacity: 0.35;
  }

  .cal-day--trip {
    background: color-mix(in srgb, var(--dest-color) 18%, transparent);
    cursor: pointer;
  }

  .cal-day--trip:hover {
    filter: brightness(0.92);
    transform: scale(1.08);
    z-index: 2;
  }

  .cal-day--first {
    border-top-left-radius: 10px;
    border-bottom-left-radius: 10px;
  }

  .cal-day--last {
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
  }

  .cal-day--today .day-num {
    background: var(--text);
    color: var(--bg);
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .day-num {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1;
  }

  .cal-day--trip .day-num {
    color: color-mix(in srgb, var(--dest-color) 90%, black);
  }

  .day-month {
    font-size: 0.5rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .cal-day--trip .day-month {
    color: color-mix(in srgb, var(--dest-color) 80%, black);
    opacity: 0.8;
  }

  /* Popup (identical to Timeline version) */
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .popup-overlay[hidden] { display: none; }

  .popup {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 32px;
    max-width: 580px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: var(--shadow-lg);
  }

  .popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px 8px;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }

  .popup-close:hover { color: var(--text); background: var(--bg); }

  .popup-title { font-size: 1.6rem; margin-bottom: 4px; }
  .popup-dates { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 24px; }

  .popup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .popup-block {
    background: var(--bg);
    border-radius: var(--radius);
    padding: 16px;
  }

  .popup-block--full { grid-column: 1 / -1; }

  .popup-block-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .popup-icon { font-size: 1rem; }
  .popup-sub { font-weight: 500; font-size: 0.9rem; margin-bottom: 4px; }

  #popup-travel-details,
  #popup-hotel-address {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  #popup-activities {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #popup-activities li {
    font-size: 0.88rem;
    padding-left: 16px;
    position: relative;
  }

  #popup-activities li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--text-muted);
    font-size: 0.75rem;
    top: 2px;
  }

  .popup-cta {
    display: inline-block;
    background: var(--text);
    color: #fff;
    padding: 10px 20px;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .popup-cta:hover { opacity: 0.85; }

  /* Responsive */
  @media (max-width: 600px) {
    .popup-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
